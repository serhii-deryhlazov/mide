{
  "app": {
    "title": "mide",
    "topStatusDefault": " mide "
  },
  "editor": {
    "lineNumbers": true,
    "highlightCurrentLine": true,
    "autoIndent": true,
    "startInEditMode": false,

    "backgroundColor": "#6b896f",
    "foregroundColor": "#fefefe",
    "browseBackgroundColor": "#6b896f",
    "currentLineHighlightColor": "#7c9e81",
    "lineNumberColor": "#fef4e2",

    "syntaxKeywordColor": "#ffe5fa",
    "syntaxTypeColor": "#c6fafd",
    "syntaxStringColor": "#feefd3",
    "syntaxCommentColor": "#c8ffc8",
    "syntaxNumberColor": "#bbfff4",
    "syntaxPunctuationColor": "#e9ffe1",
    "syntaxIdentifierColor": "#fefefe",
    "syntaxJsonKeyColor": "#e4f3d6",
    "syntaxMarkdownHeadColor": "#fcd0b1",
    "syntaxMarkdownBoldColor": "#fefefe",
    "syntaxPythonDecorColor": "#fddcec"
  },
  "tree": {
    "highlightBackgroundColor": "#7c9e81",
    "folderColor": "#ffd700",
    "visibleOnStart": false,
    "width": 30,
    "maxDepth": 3,
    "refreshIntervalSeconds": 5,
    "ignoredDirs": [ "bin", "obj", "node_modules", "__pycache__", ".git" ]
  },
  "layout": {
    "padding": 2,
    "minEditorWidth": 10,
    "minCommandWidth": 20
  },
  "dialogs": {
    "fileFilter": "*.cs;*.py;*.js;*.ts;*.json;*.md;*.txt;*.*",
    "findWidth": 50,
    "findHeight": 8,
    "gotoWidth": 40,
    "gotoHeight": 7,
    "commandHeight": 3
  },
  "startup": {
    "readmeCandidates": [ "README.md", "Readme.md", "README.txt", "README" ]
  }
}

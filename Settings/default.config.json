{
  "app": {
    "title": "mide",
    "topStatusDefault": " mide "
  },
  "editor": {
    "lineNumbers": true,
    "highlightCurrentLine": true,
    "autoIndent": true,
    "startInEditMode": false,

    "backgroundColor": "#071235",
    "foregroundColor": "#ffffff",
    "browseBackgroundColor": "#071028",
    "currentLineHighlightColor": "#122244",

    "syntaxKeywordColor": "#ff6ae0",
    "syntaxTypeColor": "#2af5ff",
    "syntaxStringColor": "#ffb020",
    "syntaxCommentColor": "#8ef08e",
    "syntaxNumberColor": "#00ffd5",
    "syntaxPunctuationColor": "#ff88ff",
    "syntaxIdentifierColor": "#ffffff",
    "syntaxJsonKeyColor": "#7efc00",
    "syntaxMarkdownHeadColor": "#ff7a18",
    "syntaxMarkdownBoldColor": "#ffffff",
    "syntaxPythonDecorColor": "#ff2d95"
  },
  "tree": {
    "visibleOnStart": false,
    "width": 30,
    "maxDepth": 3,
    "refreshIntervalSeconds": 5,
    "ignoredDirs": [ "bin", "obj", "node_modules", "__pycache__" ]
  },
  "layout": {
    "padding": 2,
    "minEditorWidth": 10,
    "minCommandWidth": 20
  },
  "dialogs": {
    "fileFilter": "*.cs;*.py;*.js;*.ts;*.json;*.md;*.txt;*.*",
    "findWidth": 50,
    "findHeight": 8,
    "gotoWidth": 40,
    "gotoHeight": 7,
    "commandHeight": 3
  },
  "startup": {
    "readmeCandidates": [ "README.md", "Readme.md", "README.txt", "README" ]
  }
}
